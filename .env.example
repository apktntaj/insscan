# Copy file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke repository

# ── INSW API ──────────────────────────────────────────────────────────────────
# Token autentikasi untuk endpoint CMS INSW (HS code detail & LARTAS)
# Format: "Basic <jwt-token>"
# Token bisa didapat dari portal SSO INSW: https://sso.insw.go.id
INSW_CMS_TOKEN=

# Alias alternatif untuk token yang sama
INSW_BEARER_TOKEN=

# ── INSW Mode Flags ───────────────────────────────────────────────────────────
# Set "true" untuk skip endpoint authenticated, pakai public endpoint saja
INSW_PUBLIC_ONLY_MODE=

# Set "true" untuk pakai mock data lokal saat development
INSW_USE_LOCAL_MOCK=

# Set "true" untuk pakai mock data saja, tanpa live API call
INSW_MOCK_ONLY_MODE=

# Path custom ke file mock JSON (opsional)
INSW_MOCK_FILE_PATH=

# ── INSW Rate Limiting ────────────────────────────────────────────────────────
# Delay antar request ke INSW API (dalam milidetik)
INSW_REQUEST_DELAY_MIN_MS=
INSW_REQUEST_DELAY_MAX_MS=

# Cooldown setelah error (dalam milidetik)
INSW_REQUEST_ERROR_COOLDOWN_MS=

