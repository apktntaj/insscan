# Copy file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke repository

# ── INSW API ──────────────────────────────────────────────────────────────────
# Token CMS INSW kini di-refresh otomatis via SSO INSW.
# Tidak perlu set INSW_CMS_TOKEN manual lagi.
#
# Client credentials INSW (dari JS bundle insw.go.id — bukan rahasia user)
INSW_CLIENT_ID=
INSW_CLIENT_BEARER=

# ── INSW Mode Flags ───────────────────────────────────────────────────────────
# Set "true" untuk skip endpoint authenticated, pakai public endpoint saja
INSW_PUBLIC_ONLY_MODE=

# Set "true" untuk pakai mock data lokal saat development
INSW_USE_LOCAL_MOCK=

# Set "true" untuk pakai mock data saja, tanpa live API call
INSW_MOCK_ONLY_MODE=

# Path custom ke file mock JSON (opsional)
INSW_MOCK_FILE_PATH=

# ── INSW Rate Limiting ────────────────────────────────────────────────────────
# Delay antar request ke INSW API (dalam milidetik)
# Biarkan kosong/0 untuk fetch secepat mungkin tanpa pacing buatan.
INSW_REQUEST_DELAY_MIN_MS=
INSW_REQUEST_DELAY_MAX_MS=

# Cooldown setelah error (dalam milidetik)
# Biarkan kosong/0 untuk menghilangkan delay setelah error.
INSW_REQUEST_ERROR_COOLDOWN_MS=


# ── Gemini API ────────────────────────────────────────────────────────────────
# API key untuk Google Gemini AI (untuk ekstraksi BL otomatis)
# Dapatkan dari: https://makersuite.google.com/app/apikey
# PENTING: Jangan commit API key ke repository
GEMINI_API_KEY=

