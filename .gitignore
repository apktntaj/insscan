# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Environment & Secrets ─────────────────────────────────────────────────────
# Never commit real credentials or tokens
.env
.env.*
!.env.example

# ── Next.js ───────────────────────────────────────────────────────────────────
/.next/
/out/

# ── Build output ──────────────────────────────────────────────────────────────
/build
/dist

# ── Testing & Coverage ────────────────────────────────────────────────────────
/coverage
/xl/
/docProps/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/settings.json
.vscode/launch.json
.idea/

# ── Kiro IDE ──────────────────────────────────────────────────────────────────
.db-profiles.local.json

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Misc ──────────────────────────────────────────────────────────────────────
/prisma/
.vercel
.github/
materi-pabean/